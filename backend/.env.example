# Application Settings
DEBUG=False
APP_NAME=Smart Receipt Analysis & Anomaly Detection
APP_VERSION=0.1.0

# Database Configuration
MONGO_URL=mongodb://localhost:27017
MONGO_DB=receipt_db

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

POSTGRES_URL=postgresql://user:password@localhost:5432/receipt_db

# Model Paths
TESSERACT_PATH=/usr/bin/tesseract  # Linux/Mac - adjust for Windows
LAYOUTLMV3_MODEL_PATH=microsoft/layoutlmv3-base
LAYOUTLMV3_CHECKPOINT=models/layoutlmv3-finetuned-cord/

# API Configuration
API_V1_STR=/api/v1
CORS_ORIGINS=*

# Feature Flags
ENABLE_RECIPE_ASSISTANT=True
ENABLE_CHATBOT=True
ENABLE_FORECASTING=True

# Anomaly Detection Thresholds
ANOMALY_SCORE_THRESHOLD=0.65
EWMA_ALPHA=0.3
ISOLATION_FOREST_CONTAMINATION=0.1

# Forecasting Configuration
FORECAST_WINDOW_DAYS=30
MIN_HISTORY_DAYS=14

# External APIs
OPENAI_API_KEY=your_openai_api_key_here

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# File Storage
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Logging
LOG_LEVEL=INFO
